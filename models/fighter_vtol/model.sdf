    <joint name='left_aileron_joint' type='revolute'>
      <pose>0.75 0 0.036 0 0 0</pose> <!-- joint  in global (-0.157,y,0.037) pose here x = -0.157-(-0.907) = 0.75 , any y, z = 0.037-(0.021) = 0.036 -->
