            <scale>0.001 0.001 0.001</scale>
            <uri>model://fighter_vtol/meshes/gz_fighter_vtol_right_elevator_v2.dae</uri>
          </mesh>
        </geometry>
        <material>
          <ambient>0 0 1 1.0</ambient>
          <diffuse>0 0 1 1.0</diffuse>
        </material>
      </visual>
    </link>

    <!-- rudder -->
    <link name="rudder">
      <pose> 0 0 0 0 0 0</pose>
      <inertial>
          <pose>0 0 0 0 0 0</pose> <!-- use (CG in fusion - link_pose) -->
          <mass>0.0016</mass>
          <inertia>
          <ixx>0.000001</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.000001</iyy>
          <iyz>0.0</iyz>
          <izz>0.000001</izz>
          </inertia>
        </inertial>
      <visual name='rudder_visual'>
        <pose> 0 0 0 0 0 0</pose>
        <geometry>
          <mesh>
            <scale>0.001 0.001 0.001</scale>
            <uri>model://fighter_vtol/meshes/gz_fighter_vtol_rudder_v2.dae</uri>
          </mesh>
        </geometry>
        <material>
          <ambient>0 0 1 1</ambient>
          <diffuse>0 0 1 1</diffuse>
        </material>
      </visual>
    </link>

    <!-- Joints -->

    <!-- pusher-fuselage joint-->
    <!-- Joint axis +Z after 90° pitch rotation produces thrust in +X (forward) direction -->
    <joint name='rotor_pusher_joint' type='revolute'>
      <pose>0 0 0 0 0 0</pose>
      <child>rotor_pusher</child>
      <parent>base_link</parent>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e+16</lower>
          <upper>1e+16</upper>
        </limit>
        <dynamics>
          <spring_reference>0</spring_reference>
          <spring_stiffness>0</spring_stiffness>
        </dynamics>
      </axis>
    </joint>

    <!-- rotor_0-fuselage joint -->
    <joint name='rotor_0_joint' type='revolute'>
      <child>rotor_0</child>
      <parent>base_link</parent>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e+16</lower>
          <upper>1e+16</upper>
        </limit>
        <dynamics>
          <spring_reference>0</spring_reference>
          <spring_stiffness>0</spring_stiffness>
        </dynamics>
      </axis>
    </joint>

    <!-- rotor_1-fuselage joint -->
    <joint name='rotor_1_joint' type='revolute'>
      <child>rotor_1</child>
      <parent>base_link</parent>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e+16</lower>
          <upper>1e+16</upper>
        </limit>
        <dynamics>
          <spring_reference>0</spring_reference>
          <spring_stiffness>0</spring_stiffness>
        </dynamics>
      </axis>
    </joint>

    <!-- rotor_2-fuselage joint -->
    <joint name='rotor_2_joint' type='revolute'>
      <child>rotor_2</child>
      <parent>base_link</parent>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e+16</lower>
          <upper>1e+16</upper>
        </limit>
        <dynamics>
          <spring_reference>0</spring_reference>
          <spring_stiffness>0</spring_stiffness>
        </dynamics>
      </axis>
    </joint>

    <!-- rotor_3-fuselage joint -->
    <joint name='rotor_3_joint' type='revolute'>
      <child>rotor_3</child>
      <parent>base_link</parent>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-1e+16</lower>
          <upper>1e+16</upper>
        </limit>
        <dynamics>
          <spring_reference>0</spring_reference>
          <spring_stiffness>0</spring_stiffness>
        </dynamics>
      </axis>
    </joint>


    <joint name='left_aileron_joint' type='revolute'>
      <pose>-0.16 0.92 0.045 0 0 0</pose> <!-- joint  in global (-0.157,y,0.037) pose here x = -0.157-(-0.907) = 0.75 , any y, z = 0.037-(0.021) = 0.036 -->
      <parent>base_link</parent>
      <child>left_aileron</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-0.44</lower>
          <upper>0.44</upper>
        </limit>
        <dynamics>
          <damping>0.3</damping>
        </dynamics>
      </axis>
      <physics>
        <ode>
          <implicit_spring_damper>1</implicit_spring_damper>
        </ode>
      </physics>
    </joint>

    <joint name='right_aileron_joint' type='revolute'>
      <pose>-0.16 -0.92 0.045 0 0 0</pose>
      <parent>base_link</parent>
      <child>right_aileron</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-0.44</lower>
          <upper>0.44</upper>
        </limit>
        <dynamics>
          <damping>0.3</damping>
        </dynamics>
      </axis>
      <physics>
        <ode>
          <implicit_spring_damper>1</implicit_spring_damper>
        </ode>
      </physics>
    </joint>


    <joint name='left_elevator_joint' type='revolute'>
      <pose> -0.93 0.2 -0.015 0 0 0</pose> <!-- global (-0.932, y, -0.016) x = -0.932 -(-1.683) = 0.751, any y, z = -0.016 - (0.0) = -0.016 ~ 0 -->
      <parent>base_link</parent>
      <child>left_elevator</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-0.44</lower>
          <upper>0.44</upper>
        </limit>
        <dynamics>
          <damping>0.3</damping>
        </dynamics>
      </axis>
      <physics>
        <ode>
          <implicit_spring_damper>1</implicit_spring_damper>
        </ode>
      </physics>
    </joint>


    <joint name='right_elevator_joint' type='revolute'>
      <pose> -0.93 -0.2 -0.015 0 0 0</pose>
      <parent>base_link</parent>
      <child>right_elevator</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-0.44</lower>
          <upper>0.44</upper>
        </limit>
        <dynamics>
          <damping>0.3</damping>
        </dynamics>
      </axis>
      <physics>
        <ode>
          <implicit_spring_damper>1</implicit_spring_damper>
        </ode>
      </physics>
    </joint>


    <joint name='rudder_joint' type='revolute'>
      <pose> -0.886 0 0.045 0 0 0</pose> <!-- global (-0.886, -0.008, z), x =  -0.886 -(-1.636) = 0.75, y = 0 (symmetric), any z-->
      <parent>base_link</parent>
      <child>rudder</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-0.5</lower>
          <upper>0.5</upper>
        </limit>
        <dynamics>
          <damping>0.3</damping>
        </dynamics>
      </axis>
      <physics>
        <ode>
          <implicit_spring_damper>1</implicit_spring_damper>
        </ode>
      </physics>
    </joint>

    <!-- Joints end -->

    <!-- Dynamical model Plugins -->

    <!-- left aileron -->
    <plugin filename="gz-sim-lift-drag-system" name="gz::sim::systems::LiftDrag">
    <link_name>base_link</link_name>
    <air_density>1.225</air_density>


    <area>0.365</area> <!-- Total area per wing half = 0.365 m² -->
    <forward>1 0 0</forward>
    <upward>0 0 1</upward>

    <cp>-0.05 0.5 0.05</cp>
    <!-- NACA-5411-->
    <a0>0.08727</a0> <!-- 5 degrees in radians -->
    <cla>6.19</cla> <!-- 0.1081 [1/deg] * (180/pi) = 6.19 [1/rad] -->
    <cla_stall>-2.44</cla_stall> <!-- -0.0427[1/deg]*(180/pi)= -2.44 [1/rad] -->
    <alpha_stall>0.27227</alpha_stall> <!-- 10.6 + a0 = 15.6 degrees in radians -->

    <cda>1.0</cda> <!-- Increased from 0.0974 to add realistic parasitic drag (rc_cessna uses 1.5) -->
    <cda_stall>-0.85371</cda_stall> <!-- 0.0149 [1/deg] * (180/pi)=0.85371, put a minus sign here following the convention from standard vtol-->
    <cma>0.0</cma>
    <cma_stall>0.0</cma_stall>

    <control_joint_name>left_aileron_joint</control_joint_name>
    <control_joint_rad_to_cl>-0.5</control_joint_rad_to_cl>
  </plugin>
  <plugin
    filename="gz-sim-joint-position-controller-system"
    name="gz::sim::systems::JointPositionController">
    <joint_name>left_aileron_joint</joint_name>
    <sub_topic>servo_0</sub_topic>
    <p_gain>10</p_gain>
  </plugin>

  <!-- right aileron -->
  <plugin filename="gz-sim-lift-drag-system" name="gz::sim::systems::LiftDrag">
    <link_name>base_link</link_name>
    <air_density>1.225</air_density>

    <area>0.365</area> <!-- 309*515 + (309+ 280)*700/2 ~= 365285mm2 = 0.0365285m2 -->
    <forward>1 0 0</forward>
    <upward>0 0 1</upward>

    <cp>-0.05 -0.5 0.05</cp>
    <!--NACA-5411-->
    <a0>0.08727</a0> <!-- 5 degrees in radians -->
    <cla>6.19</cla> <!-- 0.1081 [1/deg] * (180/pi) = 6.19 [1/rad] -->
    <cla_stall>-2.44</cla_stall> <!-- -0.0427[1/deg]*(180/pi)= -2.44 [1/rad] -->
    <alpha_stall>0.27227</alpha_stall> <!-- 10.6 + a0 = 15.6 degrees in radians -->

    <cda>1.0</cda> <!-- Increased from 0.0974 to add realistic parasitic drag (rc_cessna uses 1.5) -->
    <cda_stall>-0.85371</cda_stall> <!-- 0.0149 [1/deg] * (180/pi)=0.85371, put a minus sign here following the convention from standard vtol-->
    <cma>0.0</cma>
    <cma_stall>0.0</cma_stall>

    <control_joint_name>right_aileron_joint</control_joint_name>
    <control_joint_rad_to_cl>-0.5</control_joint_rad_to_cl>
  </plugin>
  <plugin
    filename="gz-sim-joint-position-controller-system"
    name="gz::sim::systems::JointPositionController">
    <joint_name>right_aileron_joint</joint_name>
    <sub_topic>servo_1</sub_topic>
    <p_gain>10</p_gain>
  </plugin>

  <!-- left elevator -->
    <plugin filename="gz-sim-lift-drag-system" name="gz::sim::systems::LiftDrag">
      <link_name>base_link</link_name>
      <air_density>1.225</air_density>

    <area>0.0705</area> <!-- (219+ 175)*359/2 ~= 70500mm2 = 0.0705m2 -->
    <forward>1 0 0</forward>
    <upward>0 0 1</upward>

    <cp>-1.0 0.2 -0.05</cp>
    <!--NACA-0009-->
    <a0>0</a0> <!-- 0 degrees in radians -->
    <cla>7.02</cla> <!-- 0.1226 [1/deg] * (180/pi) = 7.02 [1/rad] -->
    <cla_stall>-8.02</cla_stall> <!-- -0.1399[1/deg]*(180/pi)= -8.02 [1/rad] -->
    <alpha_stall>0.15708</alpha_stall> <!-- 9 + a0 = 9 degrees in radians -->

    <cda>0.6</cda> <!-- Increased from 0.14897 for realistic drag (rc_cessna uses 0.64) -->
    <cda_stall>-1.2490</cda_stall> <!-- 0.0218 [1/deg] * (180/pi)=1.24905, put a minus sign here following the convention from standard vtol-->
    <cma>0.0</cma>
    <cma_stall>0.0</cma_stall>

      <control_joint_name>left_elevator_joint</control_joint_name>
      <control_joint_rad_to_cl>-4.0</control_joint_rad_to_cl>
    </plugin>
    <plugin
      filename="gz-sim-joint-position-controller-system"
      name="gz::sim::systems::JointPositionController">
      <joint_name>left_elevator_joint</joint_name>
      <sub_topic>servo_2</sub_topic>
      <p_gain>10</p_gain>
    </plugin>

  <!-- right elevator -->
  <plugin filename="gz-sim-lift-drag-system" name="gz::sim::systems::LiftDrag">
    <link_name>base_link</link_name>
    <air_density>1.225</air_density>

    <area>0.0705</area> <!-- (219+ 175)*359/2 ~= 70500mm2 = 0.0705m2 -->
    <forward>1 0 0</forward>
    <upward>0 0 1</upward>

    <cp>-1.0 -0.2 -0.05</cp>

    <!--NACA-0009-->
    <a0>0</a0> <!-- 0 degrees in radians -->
    <cla>7.02</cla> <!-- 0.1226 [1/deg] * (180/pi) = 7.02 [1/rad] -->
    <cla_stall>-8.02</cla_stall> <!-- -0.1399[1/deg]*(180/pi)= -8.02 [1/rad] -->
    <alpha_stall>0.15708</alpha_stall> <!-- 9 + a0 = 9 degrees in radians -->

    <cda>0.6</cda> <!-- Increased from 0.14897 for realistic drag (rc_cessna uses 0.64) -->
    <cda_stall>-1.2490</cda_stall> <!-- 0.0218 [1/deg] * (180/pi)=1.24905, put a minus sign here following the convention from standard vtol-->
    <cma>0.0</cma>
    <cma_stall>0.0</cma_stall>

    <control_joint_name>right_elevator_joint</control_joint_name>
    <control_joint_rad_to_cl>-4.0</control_joint_rad_to_cl>
  </plugin>
  <plugin
    filename="gz-sim-joint-position-controller-system"
    name="gz::sim::systems::JointPositionController">
    <joint_name>right_elevator_joint</joint_name>
    <sub_topic>servo_3</sub_topic>
    <p_gain>10</p_gain>
  </plugin>

  <!-- rudder assume no aerao dynamic effect right now-->
  <plugin filename="gz-sim-lift-drag-system" name="gz::sim::systems::LiftDrag">
      <link_name>base_link</link_name>
      <air_density>1.225</air_density>
      <area>0.035</area>
      <forward>1 0 0</forward>
      <upward>0 1 0</upward> <!-- the rudder serves as a "vertical airfoil"-->
      <cp>-1.63 0 0.45</cp>

    <!--NACA-0009-->
    <a0>0</a0> <!-- 0 degrees in radians -->
    <cla>7.02</cla> <!-- 0.1226 [1/deg] * (180/pi) = 7.02 [1/rad] -->
    <cla_stall>-8.02</cla_stall> <!-- -0.1399[1/deg]*(180/pi)= -8.02 [1/rad] -->
    <alpha_stall>0.15708</alpha_stall> <!-- 9 + a0 = 9 degrees in radians -->

    <cda>0.6</cda> <!-- Increased from 0.14897 for realistic drag (rc_cessna uses 0.64) -->
    <cda_stall>-1.2490</cda_stall> <!-- 0.0218 [1/deg] * (180/pi)=1.24905, put a minus sign here following the convention from standard vtol-->
    <cma>0.0</cma>
    <cma_stall>0.0</cma_stall>

      <control_joint_name>rudder_joint</control_joint_name>
      <control_joint_rad_to_cl>0.8</control_joint_rad_to_cl>
    </plugin>
    <plugin
      filename="gz-sim-joint-position-controller-system"
      name="gz::sim::systems::JointPositionController">
      <joint_name>rudder_joint</joint_name>
      <sub_topic>servo_4</sub_topic>
      <p_gain>10</p_gain>
    </plugin>

    <!-- rotor 1 -->
    <plugin filename="gz-sim-multicopter-motor-model-system"
      name="gz::sim::systems::MulticopterMotorModel">
      <jointName>rotor_0_joint</jointName>
      <linkName>rotor_0</linkName>
      <turningDirection>ccw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>1055</maxRotVelocity>
      <motorConstant>7.6e-05</motorConstant>
      <momentConstant>0.0205</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic>
      <motorNumber>0</motorNumber>
      <rotorDragCoefficient>0.000106428</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <rotorVelocitySlowdownSim>20</rotorVelocitySlowdownSim>
      <motorType>velocity</motorType>
    </plugin>

    <!-- rotor 2 -->
    <plugin
      filename="gz-sim-multicopter-motor-model-system"
      name="gz::sim::systems::MulticopterMotorModel">
      <jointName>rotor_1_joint</jointName>
      <linkName>rotor_1</linkName>
      <turningDirection>ccw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>1055</maxRotVelocity>
      <motorConstant>7.6e-05</motorConstant>
      <momentConstant>0.0205</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic>
      <motorNumber>1</motorNumber> <!-- PX4 start with 0 -->
      <rotorDragCoefficient>0.000106428</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <rotorVelocitySlowdownSim>20</rotorVelocitySlowdownSim>
      <motorType>velocity</motorType>
    </plugin>

    <!-- rotor 3 -->
    <plugin
      filename="gz-sim-multicopter-motor-model-system"
      name="gz::sim::systems::MulticopterMotorModel">
      <jointName>rotor_2_joint</jointName>
      <linkName>rotor_2</linkName>
      <turningDirection>cw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>1055</maxRotVelocity>
      <motorConstant>7.6e-05</motorConstant>
      <momentConstant>0.0205</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic>
      <motorNumber>2</motorNumber>
      <rotorDragCoefficient>0.000106428</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <rotorVelocitySlowdownSim>20</rotorVelocitySlowdownSim>
      <motorType>velocity</motorType>
    </plugin>

    <!-- rotor 4 -->
    <plugin filename="gz-sim-multicopter-motor-model-system"
      name="gz::sim::systems::MulticopterMotorModel">
      <jointName>rotor_3_joint</jointName>
      <linkName>rotor_3</linkName>
      <turningDirection>cw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>1055</maxRotVelocity>
      <motorConstant>7.6e-05</motorConstant>
      <momentConstant>0.0205</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic>
      <motorNumber>3</motorNumber>
      <rotorDragCoefficient>0.000106428</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <rotorVelocitySlowdownSim>20</rotorVelocitySlowdownSim>
      <motorType>velocity</motorType>
    </plugin>

    <!-- pusher rotor -->
    <plugin
      filename="gz-sim-multicopter-motor-model-system"
      name="gz::sim::systems::MulticopterMotorModel">
      <jointName>rotor_pusher_joint</jointName>
      <linkName>rotor_pusher</linkName>
      <turningDirection>cw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>826</maxRotVelocity>
      <motorConstant>1.096e-04</motorConstant>
      <momentConstant>0.02807</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic>
      <motorNumber>4</motorNumber>
      <rotorDragCoefficient>0.000106428</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <rotorVelocitySlowdownSim>20</rotorVelocitySlowdownSim>
      <motorType>velocity</motorType>
    </plugin>
    <!-- Airspeed sensor -->
    <include merge='true'>
      <uri>model://airspeed</uri>
      <pose>0.5 0 0 0 0 0</pose>
    </include>
    <joint name='airspeed_joint' type='fixed'>
      <parent>base_link</parent>
      <child>airspeed_link</child>
    </joint>
    <static>0</static>
  </model>
</sdf>
