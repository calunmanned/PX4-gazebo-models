      <pose> 0.75 0 -0.016 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-0.78</lower>
          <upper>0.78</upper>
        </limit>
        <dynamics>
          <damping>1.000</damping>
        </dynamics>
      </axis>
      <physics>
        <ode>
          <implicit_spring_damper>1</implicit_spring_damper>
        </ode>
      </physics>
    </joint>


    <joint name='rudder_joint' type='revolute'>
      <pose> 0.75 0 0 0 0 0</pose> <!-- global (-0.886, -0.008, z), x =  -0.886 -(-1.636) = 0.75, y = 0 (symmetric), any z-->
      <parent>base_link</parent>
      <child>rudder</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-0.78</lower>
          <upper>0.78</upper>
        </limit>
        <dynamics>
          <damping>1.000</damping>
        </dynamics>
      </axis>
      <physics>
        <ode>
          <implicit_spring_damper>1</implicit_spring_damper>
        </ode>
      </physics>
    </joint>

    <!-- Joints end -->

    <!-- Dynamical model Plugins -->
    <!-- left aileron -->
    <plugin filename="gz-sim-lift-drag-system" name="gz::sim::systems::LiftDrag">
    <link_name>base_link</link_name>
    <air_density>1.225</air_density>
    <area>0.365</area>
    <forward>1 0 0</forward>
    <upward>0 0 1</upward>
    
    <cp>0.736 -0.86 0.339</cp> 
    
    <a0>-0.1347</a0>
    <cla>4.760</cla>
    <cda>0.05</cda>
    <cma>3.698</cma>
    <alpha_stall>0.33</alpha_stall>
    <cla_stall>-0.2</cla_stall>
    <cda_stall>1.0</cda_stall>
    <cma_stall>0.0</cma_stall>

    <control_joint_name>left_aileron_joint</control_joint_name>
    <control_joint_rad_to_cl>0.0137</control_joint_rad_to_cl> 
  </plugin>
    <plugin
      filename="gz-sim-joint-position-controller-system"
      name="gz::sim::systems::JointPositionController">
      <joint_name>left_aileron_joint</joint_name>
      <sub_topic>servo_0</sub_topic> <!-- this is the default topic px4 publish-->
    </plugin>

    <!-- right aileron -->
    <plugin filename="gz-sim-lift-drag-system" name="gz::sim::systems::LiftDrag">
