        </geometry>
        <material>
          <ambient>0 0 1 1.0</ambient>
          <diffuse>0 0 1 1.0</diffuse>
        </material>
      </visual>
    </link>

    <!-- right elevator-->
    <link name="right_elevator">
      <pose> 0 0 0 0 0 0</pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose> <!-- use (CG in fusion - link_pose) -->
        <mass>0.0025</mass>
        <inertia>
          <ixx>0.000001</ixx>
          <ixy>0.0</ixy>
          <iyy>0.000001</iyy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
          <izz>0.000001</izz>
        </inertia>
      </inertial>
